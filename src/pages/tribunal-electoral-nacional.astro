---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.jsx";
import Footer from "../components/Footer.jsx";
import TribunalElectoralNacional from "../components/tribunal-electoral-nacional/TribunalElectoralNacional.jsx";
---

<Layout title="Tribunal Electoral Nacional | Integridad Democrática">
	<Navbar client:load />

	<!-- Banner Tribunal Electoral Nacional -->
	<section class="tribunal-banner" id="tribunal-banner">
		<div class="tribunal-banner__overlay"></div>
		<div class="tribunal-banner__content">
			<h1 class="tribunal-banner__title" data-i18n="leadership.electoral.banner">Tribunal Electoral Nacional</h1>
		</div>
	</section>

	<main id="tribunal-main">
		<TribunalElectoralNacional client:load />
	</main>

	<Footer />
</Layout>

<style>
	.tribunal-banner {
		position: relative;
		width: 100%;
		height: clamp(180px, 22vw, 280px);
		background-color: #003580;
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
	}

	.tribunal-banner::before {
		content: "";
		position: absolute;
		inset: 0;
		background-image: url("../img/principiosimg.webp");
		background-size: cover;
		background-position: center;
		background-repeat: no-repeat;
		opacity: 0.35;
		z-index: 0;
	}

	.tribunal-banner__overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			135deg,
			rgba(0, 30, 80, 0.55) 0%,
			rgba(0, 53, 128, 0.40) 50%,
			rgba(0, 30, 80, 0.55) 100%
		);
		z-index: 1;
	}

	.tribunal-banner__content {
		position: relative;
		z-index: 2;
		text-align: center;
		padding-inline: clamp(16px, 4vw, 48px);
	}

	.tribunal-banner__title {
		font-family: "Proxima Nova", Arial, sans-serif;
		font-size: clamp(28px, 3.6vw, 52px);
		font-weight: 800;
		color: #f7ffff;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		margin: 0;
		text-shadow: 0 4px 18px rgba(0, 16, 54, 0.32);
	}
</style>

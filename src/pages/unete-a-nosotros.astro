---
import Navbar from "../components/Navbar.jsx";
import Footer from "../components/Footer.jsx";
import Layout from "../layouts/Layout.astro";

const fichaUrl = "/recursos/ficha-afilaciones/FICHADEAFILIACIONJNE748.pdf";
---

<Layout title="Únete a nosotros - Integridad Democrática">
	<Navbar client:load />

		<section class="join-hero" aria-labelledby="join-title">
			<div class="join-hero__backdrop"></div>
			<div class="join-hero__content">
				<h1 id="join-title" data-i18n="join.title">Únete a nosotros</h1>
				<p data-i18n="join.copy">
					Completa tus datos y descarga la ficha oficial de afiliación para iniciar tu incorporación a
					Integridad Democrática.
				</p>
			</div>
		</section>

	<main class="join-page">
		<section class="join-shell" aria-label="Formulario de afiliación" data-i18n-aria-label="join.formAria">
			<div class="join-panel join-panel--intro">
				<div class="join-video-card">
					<div class="join-video-card__header">
						<span data-i18n="join.videoInfo">Video informativo</span>
						<strong data-i18n="join.affiliation">Afiliación</strong>
					</div>
					<div class="join-video">
						<iframe
							src="https://www.youtube.com/embed/bVbN1Z-9gB8?autoplay=1&mute=1&playsinline=1&rel=0&modestbranding=1"
							title="Video de afiliación de Integridad Democrática"
							data-i18n-title="join.videoTitle"
							allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
							allowfullscreen
						></iframe>
					</div>
				</div>
				<a class="join-panel__download" href={fichaUrl} download>
					<span aria-hidden="true">
						<svg viewBox="0 0 24 24">
							<path d="M12 3a1 1 0 0 1 1 1v8.59l2.3-2.3a1 1 0 1 1 1.4 1.42l-4 4a1 1 0 0 1-1.4 0l-4-4a1 1 0 1 1 1.4-1.42l2.3 2.3V4a1 1 0 0 1 1-1Z" />
							<path d="M5 18a1 1 0 0 1 1-1h12a1 1 0 1 1 0 2H6a1 1 0 0 1-1-1Z" />
						</svg>
					</span>
					<span data-i18n="join.download">Descargar ficha PDF</span>
				</a>
			</div>

			<form class="join-form" action="#" method="post">
				<div class="form-section">
					<div class="form-section__header">
						<span>01</span>
						<h3 data-i18n="join.personalData">Datos personales</h3>
					</div>

					<label class="field field--full">
						<span><span data-i18n="join.lastNames">Apellidos</span> <strong>*</strong></span>
						<input name="apellidos" type="text" autocomplete="family-name" required />
					</label>

					<label class="field field--full">
						<span><span data-i18n="join.names">Nombres</span> <strong>*</strong></span>
						<input name="nombres" type="text" autocomplete="given-name" required />
					</label>

					<label class="field">
						<span>DNI <strong>*</strong></span>
						<input name="dni" type="text" inputmode="numeric" maxlength="8" required />
					</label>

					<label class="field">
						<span><span data-i18n="join.sex">Sexo</span> <strong>*</strong></span>
						<select name="sexo" required>
							<option value="" data-i18n="join.select">Seleccionar</option>
							<option value="femenino" data-i18n="join.female">Femenino</option>
							<option value="masculino" data-i18n="join.male">Masculino</option>
						</select>
					</label>

					<label class="field field--full">
						<span data-i18n="join.birthPlace">Lugar de nacimiento: Región / Provincia / Distrito</span>
						<input name="lugar_nacimiento" type="text" />
					</label>

					<label class="field">
						<span><span data-i18n="join.birthDate">Fecha de nacimiento</span> <strong>*</strong></span>
						<input name="fecha_nacimiento" type="date" required />
					</label>

					<label class="field">
						<span data-i18n="join.civilStatus">Estado civil</span>
						<input name="estado_civil" type="text" />
					</label>

					<label class="field">
						<span>Email</span>
						<input name="email" type="email" autocomplete="email" />
					</label>

					<label class="field">
						<span data-i18n="join.phone">Teléfono</span>
						<input name="telefono" type="tel" autocomplete="tel" />
					</label>
				</div>

				<div class="form-section">
					<div class="form-section__header">
						<span>02</span>
						<h3 data-i18n="join.currentAddress">Domicilio actual</h3>
					</div>

					<label class="field">
						<span data-i18n="join.region">Región</span>
						<input name="region" type="text" />
					</label>

					<label class="field">
						<span data-i18n="join.district">Distrito</span>
						<input name="distrito" type="text" />
					</label>

					<label class="field">
						<span data-i18n="join.province">Provincia</span>
						<input name="provincia" type="text" />
					</label>

					<label class="field">
						<span data-i18n="join.street">Avenida / Calle / Jirón</span>
						<input name="direccion" type="text" autocomplete="street-address" />
					</label>

					<label class="field field--full">
						<span data-i18n="join.neighborhood">Urbanización - Sector - Caserío</span>
						<input name="urbanizacion" type="text" />
					</label>
				</div>

				<div class="join-form__actions">
					<button type="submit" data-i18n="join.submit">Enviar</button>
				</div>
			</form>
		</section>
	</main>

	<Footer />
</Layout>

<style>
	.join-hero {
		position: relative;
		isolation: isolate;
		min-height: clamp(300px, 36vw, 440px);
		display: grid;
		align-items: end;
		overflow: hidden;
		background: #003580;
		background-image: url("../img/banner22.png");
		background-size: cover;
		background-position: center;
	}

	.join-hero__backdrop {
		position: absolute;
		inset: 0;
		z-index: -1;
		background:
			linear-gradient(90deg, rgba(0, 24, 74, 0.92), rgba(0, 73, 164, 0.68) 48%, rgba(0, 24, 74, 0.2)),
			radial-gradient(circle at 82% 20%, rgba(255, 210, 48, 0.35), transparent 34%);
	}

	.join-hero__content {
		width: min(1180px, calc(100% - 36px));
		margin: 0 auto;
		padding: clamp(46px, 7vw, 86px) 0 clamp(34px, 5vw, 58px);
		color: #f7ffff;
	}

	.join-hero__eyebrow {
		width: fit-content;
		margin: 0 0 16px;
		border: 1px solid rgba(247, 255, 255, 0.28);
		border-radius: 999px;
		background: rgba(247, 255, 255, 0.12);
		padding: 9px 14px;
		font-size: 12px;
		font-weight: 900;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		backdrop-filter: blur(14px);
	}

	.join-hero h1 {
		max-width: 780px;
		margin: 0;
		font-size: clamp(38px, 6.4vw, 82px);
		font-weight: 900;
		line-height: 0.92;
		letter-spacing: 0;
		text-transform: uppercase;
		text-shadow: 0 20px 48px rgba(0, 16, 54, 0.34);
	}

	.join-hero p:not(.join-hero__eyebrow) {
		max-width: 660px;
		margin: 22px 0 0;
		font-size: clamp(16px, 2vw, 21px);
		font-weight: 700;
		line-height: 1.5;
		color: rgba(247, 255, 255, 0.84);
	}

	.join-hero__download {
		display: inline-flex;
		min-height: 54px;
		align-items: center;
		justify-content: center;
		gap: 12px;
		margin-top: 30px;
		border-radius: 999px;
		background: #f7ffff;
		padding: 0 24px;
		color: #0049a4;
		font-size: 13px;
		font-weight: 900;
		text-decoration: none;
		text-transform: uppercase;
		box-shadow: 0 22px 44px rgba(0, 16, 54, 0.3);
		transition: transform 180ms ease, box-shadow 180ms ease;
	}

	.join-hero__download:hover {
		transform: translateY(-2px);
		box-shadow: 0 28px 56px rgba(0, 16, 54, 0.38);
	}

	.join-hero__download span {
		display: grid;
		width: 31px;
		height: 31px;
		place-items: center;
		border-radius: 999px;
		background: #0049a4;
		color: #f7ffff;
	}

	.join-hero__download svg {
		width: 18px;
		height: 18px;
		fill: currentColor;
	}

	.join-page {
		background:
			linear-gradient(180deg, #f7ffff 0%, #eef6ff 48%, #f7ffff 100%);
		padding: clamp(44px, 7vw, 92px) clamp(16px, 4vw, 48px);
	}

	.join-shell {
		display: grid;
		grid-template-columns: minmax(240px, 0.78fr) minmax(0, 1.42fr);
		gap: clamp(22px, 3vw, 42px);
		width: min(1180px, 100%);
		margin: 0 auto;
		align-items: start;
	}

	.join-panel,
	.join-form {
		border: 1px solid rgba(0, 73, 164, 0.12);
		background: rgba(255, 255, 255, 0.86);
		box-shadow: 0 28px 70px rgba(0, 43, 99, 0.12);
		backdrop-filter: blur(18px);
	}

	.join-panel {
		position: sticky;
		top: 104px;
		overflow: hidden;
		border-radius: 30px;
		padding: clamp(14px, 2vw, 18px);
		color: #001e50;
		background:
			linear-gradient(#ffffff, #ffffff) padding-box,
			linear-gradient(135deg, rgba(0, 73, 164, 0.34), rgba(247, 255, 255, 0.78), rgba(0, 73, 164, 0.16)) border-box;
		border: 1px solid transparent;
	}

	.join-panel::before {
		content: "";
		position: absolute;
		inset: -40% auto auto -35%;
		width: 220px;
		height: 220px;
		border-radius: 999px;
		background: rgba(0, 73, 164, 0.1);
		filter: blur(28px);
		pointer-events: none;
	}

	.join-video-card {
		position: relative;
		overflow: hidden;
		border: 1px solid rgba(0, 73, 164, 0.12);
		border-radius: 24px;
		background:
			linear-gradient(180deg, rgba(247, 255, 255, 0.96), rgba(238, 246, 255, 0.92)),
			#ffffff;
		padding: 10px;
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.9);
	}

	.join-video-card__header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		padding: 2px 4px 10px;
		color: #0049a4;
	}

	.join-video-card__header span,
	.join-video-card__header strong {
		display: inline-flex;
		align-items: center;
		min-height: 28px;
		border-radius: 999px;
		font-size: 11px;
		font-weight: 900;
		line-height: 1;
		text-transform: uppercase;
		white-space: nowrap;
	}

	.join-video-card__header span {
		background: rgba(0, 73, 164, 0.08);
		padding: 0 10px;
		letter-spacing: 0.1em;
	}

	.join-video-card__header strong {
		border: 1px solid rgba(0, 73, 164, 0.16);
		background: #ffffff;
		padding: 0 9px;
	}

	.join-video {
		position: relative;
		overflow: hidden;
		aspect-ratio: 16 / 9;
		border: 1px solid rgba(247, 255, 255, 0.2);
		border-radius: 18px;
		background: #001e50;
		box-shadow: 0 18px 42px rgba(0, 24, 74, 0.22);
	}

	.join-video::after {
		content: "";
		position: absolute;
		inset: 0;
		border: 1px solid rgba(255, 255, 255, 0.18);
		border-radius: inherit;
		pointer-events: none;
	}

	.join-video iframe {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		border: 0;
	}

	.join-panel__download {
		display: inline-flex;
		width: 100%;
		min-height: 58px;
		align-items: center;
		justify-content: center;
		gap: 12px;
		margin-top: 16px;
		border: 1px solid rgba(0, 73, 164, 0.14);
		border-radius: 999px;
		background: #0049a4;
		color: #f7ffff;
		font-size: clamp(12px, 1.1vw, 13px);
		font-weight: 900;
		line-height: 1;
		text-decoration: none;
		text-transform: uppercase;
		box-shadow: 0 18px 36px rgba(0, 73, 164, 0.28), inset 0 1px 0 rgba(255, 255, 255, 0.22);
		transition: transform 160ms ease, box-shadow 160ms ease, filter 160ms ease;
	}

	.join-panel__download:hover {
		transform: translateY(-2px);
		filter: saturate(1.08);
		background: #003580;
		box-shadow: 0 22px 44px rgba(0, 73, 164, 0.34);
	}

	.join-panel__download span {
		display: grid;
		width: 34px;
		height: 34px;
		flex: 0 0 auto;
		place-items: center;
		border-radius: 999px;
		background: rgba(247, 255, 255, 0.18);
		box-shadow: inset 0 0 0 1px rgba(247, 255, 255, 0.16);
	}

	.join-panel__download svg {
		width: 18px;
		height: 18px;
		fill: currentColor;
	}

	.join-form {
		display: grid;
		gap: 28px;
		border-radius: 32px;
		padding: clamp(20px, 4vw, 42px);
	}

	.form-section {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 20px;
	}

	.form-section__header {
		grid-column: 1 / -1;
		display: flex;
		align-items: center;
		gap: 12px;
		padding-bottom: 3px;
	}

	.form-section__header span {
		display: grid;
		width: 42px;
		height: 42px;
		place-items: center;
		border-radius: 14px;
		background: #0049a4;
		color: #f7ffff;
		font-size: 13px;
		font-weight: 900;
	}

	.form-section__header h3 {
		margin: 0;
		color: #001e50;
		font-size: clamp(20px, 2.2vw, 28px);
		font-weight: 900;
	}

	.field {
		display: grid;
		gap: 8px;
		min-width: 0;
	}

	.field--full {
		grid-column: 1 / -1;
	}

	.field span {
		color: #001e50;
		font-size: 13px;
		font-weight: 800;
	}

	.field strong {
		color: #e00000;
	}

	.field input,
	.field select {
		width: 100%;
		min-height: 50px;
		border: 1.5px solid rgba(0, 73, 164, 0.28);
		border-radius: 14px;
		background: #ffffff;
		padding: 0 15px;
		color: #001e50;
		font: inherit;
		font-size: 15px;
		font-weight: 700;
		outline: none;
		transition: border-color 160ms ease, box-shadow 160ms ease, transform 160ms ease;
	}

	.field input:focus,
	.field select:focus {
		border-color: #0049a4;
		box-shadow: 0 0 0 4px rgba(0, 73, 164, 0.12);
		transform: translateY(-1px);
	}

	.join-form__actions {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 16px;
		border-top: 1px solid rgba(0, 73, 164, 0.12);
		padding-top: 26px;
	}

	.join-form__actions a,
	.join-form__actions button {
		display: inline-flex;
		min-height: 50px;
		align-items: center;
		justify-content: center;
		border-radius: 999px;
		padding: 0 24px;
		font-size: 13px;
		font-weight: 900;
		text-transform: uppercase;
		text-decoration: none;
		transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease;
	}

	.join-form__actions a {
		border: 1px solid rgba(0, 73, 164, 0.24);
		color: #0049a4;
	}

	.join-form__actions button {
		border: 0;
		background: #0049a4;
		color: #f7ffff;
		box-shadow: 0 16px 34px rgba(0, 73, 164, 0.26);
		cursor: pointer;
	}

	.join-form__actions a:hover,
	.join-form__actions button:hover {
		transform: translateY(-2px);
	}

	.join-form__actions button:hover {
		background: #003580;
		box-shadow: 0 20px 42px rgba(0, 73, 164, 0.34);
	}

	@media (max-width: 900px) {
		.join-shell {
			grid-template-columns: 1fr;
		}

		.join-panel {
			position: relative;
			top: auto;
		}
	}

	@media (max-width: 640px) {
		.join-hero__content {
			width: min(100% - 28px, 1180px);
		}

		.join-panel {
			border-radius: 24px;
			padding: 10px;
		}

		.join-video-card {
			border-radius: 20px;
			padding: 8px;
		}

		.join-video-card__header {
			flex-wrap: wrap;
			padding-bottom: 8px;
		}

		.join-video-card__header span,
		.join-video-card__header strong {
			min-height: 26px;
			font-size: 10px;
		}

		.join-video {
			border-radius: 15px;
		}

		.join-panel__download {
			min-height: 54px;
			padding: 0 14px;
		}

		.form-section {
			grid-template-columns: 1fr;
		}

		.field--full {
			grid-column: auto;
		}

		.join-form__actions {
			flex-direction: column;
			align-items: stretch;
		}
	}
</style>

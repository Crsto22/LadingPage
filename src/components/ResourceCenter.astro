                  {item.titulo}
                </h3>
                {item.fecha && (
                  <p class="text-xs text-muted font-semibold group-hover:text-white/70 transition-colors duration-300">
                    {item.fecha}
                  </p>
                )}
              </div>
              <div class="flex items-center border-t border-primary/8 group-hover:border-white/20 px-5 py-3 gap-3 transition-colors duration-300">
                <button

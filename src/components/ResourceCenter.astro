---

<section class="w-full bg-surface font-primary" id="resource-center">
  <!-- Tabs -->
  <div
    class="border-b border-primary/12 bg-white/80 backdrop-blur-sm sticky top-0 z-30"
  >
    <div class="mx-auto max-w-[1540px] px-[clamp(18px,5vw,84px)]">
      <nav class="flex gap-1 -mb-px overflow-x-auto" id="rc-tabs">
        {
          [
            {
              key: "comunicados",
              label: "Comunicados",
              icon: "M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z",
            },
            {
              key: "documentos",
              label: "Documentos",
              icon: "M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z",
            },
            {
              key: "identidad",
              label: "Identidad Gráfica",
              icon: "M9.53 16.122a3 3 0 0 0-5.78 1.128 2.25 2.25 0 0 1-2.4 2.245 4.5 4.5 0 0 0 8.4-2.245c0-.399-.078-.78-.22-1.128Zm0 0a15.998 15.998 0 0 0 3.388-1.62m-5.043-.025a15.994 15.994 0 0 1 1.622-3.395m3.42 3.42a15.995 15.995 0 0 0 4.764-4.648l3.876-5.814a1.151 1.151 0 0 0-1.597-1.597L14.146 6.32a15.996 15.996 0 0 0-4.649 4.763m3.42 3.42a6.776 6.776 0 0 0-3.42-3.42",
            },
          ].map((tab) => (
            <button
              data-tab={tab.key}
              class="rc-tab group relative flex items-center gap-2 px-6 py-4 text-[13px] font-extrabold uppercase tracking-[0.06em] text-muted transition-all duration-300 hover:text-primary whitespace-nowrap cursor-pointer rounded-t-2xl"
              type="button"
            >
              <svg
                class="w-[18px] h-[18px] shrink-0"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d={tab.icon}
                />
              </svg>
              {tab.label}
              <span class="rc-tab__bar absolute bottom-0 left-3 right-3 h-[3px] bg-primary rounded-full scale-x-0 transition-transform duration-300 origin-center" />
            </button>
          ))
        }
      </nav>
    </div>
  </div>

  <!-- Panels -->
  <div
    class="mx-auto max-w-[1540px] px-[clamp(18px,5vw,84px)] py-[clamp(32px,5vw,56px)]"
  >
    <!-- Comunicados -->
    <div data-panel="comunicados" class="rc-panel hidden">
      <div class="flex items-center justify-between mb-8">
        <h2
          class="text-[clamp(20px,2.2vw,28px)] font-black text-primary-dark tracking-[-0.01em]"
        >
          Comunicados
        </h2>
        <span class="text-xs font-bold text-muted uppercase tracking-[0.12em]"
          >{comunicados.length} publicaciones</span
        >
      </div>
      <div
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5"
      >
        {
          comunicados.map((item) => (
            <article
              class="rc-card group relative flex flex-col bg-white rounded-2xl border border-primary/10 overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:bg-primary hover:border-primary hover:shadow-[0_16px_40px_rgba(0,73,164,0.28)] cursor-pointer"
              id={item.id}
              data-archivo={item.archivo}
              data-title={item.titulo}
              data-date={item.fecha}
            >
              <div class="flex-1 p-5">
                <div class="flex items-start gap-3 mb-4">
                  <div class="shrink-0 w-12 h-12 rounded-xl bg-primary/[0.06] group-hover:bg-white/15 flex items-center justify-center transition-colors duration-300">
                    <img
                      src={logoSrc.src}
                      alt=""
                      class="w-8 h-8 object-contain"
                      loading="lazy"
                    />
                  </div>
                  <span class="inline-block text-[10px] font-black uppercase tracking-[0.16em] text-primary bg-primary/[0.06] group-hover:text-white group-hover:bg-white/15 px-2.5 py-1 rounded-full mt-1 transition-colors duration-300">
                    Comunicado
                  </span>
                </div>
                <h3 class="text-[15px] font-bold text-body leading-snug mb-2 group-hover:text-white transition-colors duration-300 line-clamp-3">
                  {item.titulo}
                </h3>
                {item.fecha && (
                  <p class="text-xs text-muted font-semibold group-hover:text-white/70 transition-colors duration-300">
                    {item.fecha}
                  </p>
                )}
              </div>
              <div class="flex items-center border-t border-primary/8 group-hover:border-white/20 px-5 py-3 gap-3 transition-colors duration-300">
                <button
                  type="button"
                  class="inline-flex items-center gap-1.5 text-xs font-extrabold text-primary group-hover:text-white transition-colors duration-300"
                >
                  <svg
                    class="w-4 h-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z"
                    />
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"
                    />
                  </svg>
                  Ver
                </button>
                <span class="w-px h-4 bg-primary/12 group-hover:bg-white/25 transition-colors duration-300" />
                <a
                  href={item.archivo}
                  download
                  class="inline-flex items-center gap-1.5 text-xs font-extrabold text-muted group-hover:text-white/80 transition-colors duration-300"
                >
                  <svg
                    class="w-4 h-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"

<script is:inline>
  (() => {
    const tabs = document.querySelectorAll(".rc-tab");
    const panels = document.querySelectorAll(".rc-panel");
    const cards = document.querySelectorAll(".rc-card");
    let activeCard = null;

    function activate(tabName) {
      tabs.forEach((tab) => {
        const isActive = tab.dataset.tab === tabName;
        const bar = tab.querySelector(".rc-tab__bar");
        tab.classList.toggle("text-primary", isActive);
        tab.classList.toggle("text-muted", !isActive);
        bar.style.transform = isActive ? "scaleX(1)" : "scaleX(0)";
      });
      panels.forEach((panel) => {
        if (panel.dataset.panel === tabName) {
          panel.classList.remove("hidden");
          panel.style.animation =
            "rcFadeIn 350ms cubic-bezier(0.22,1,0.36,1) both";
        } else {
          panel.classList.add("hidden");
          panel.style.animation = "";
        }
      });
    }

    tabs.forEach((tab) =>
      tab.addEventListener("click", () => activate(tab.dataset.tab))
    );

    /* Modal Logic */
    const modal = document.getElementById("pdf-modal");
    const modalContent = document.getElementById("pdf-modal-content");
    const modalClose = document.getElementById("pdf-modal-close");
    const modalIframe = document.getElementById("pdf-modal-iframe");
    const modalTitle = document.getElementById("pdf-modal-title");
    const modalDate = document.getElementById("pdf-modal-date");
    const modalDownload = document.getElementById("pdf-modal-download");

    function openPdfModal(title, date, url) {
      modalTitle.textContent = title;

      if (date && date !== "undefined") {
        modalDate.textContent = date;
        modalDate.style.display = "block";
      } else {
        modalDate.style.display = "none";
      }

      modalDownload.href = url;
      // Set src without hash to allow native PDF toolbar (for zooming, etc.)
      modalIframe.src = encodeURI(url);

      modal.classList.remove("opacity-0", "pointer-events-none");
      modalContent.classList.remove("scale-95");
      modalContent.classList.add("scale-100");
      document.body.style.overflow = "hidden";
    }

    function closePdfModal() {
      modal.classList.add("opacity-0", "pointer-events-none");
      modalContent.classList.remove("scale-100");
      modalContent.classList.add("scale-95");
      document.body.style.overflow = "";
      setTimeout(() => {
        modalIframe.src = "";
      }, 300);
    }

    if (modalClose) modalClose.addEventListener("click", closePdfModal);
    if (modal)
      modal.addEventListener("click", (e) => {
        if (e.target === modal) closePdfModal();
      });

    /* Card click-to-open and selection */
    cards.forEach((card) => {
      card.addEventListener("click", (e) => {
        const link = e.target.closest("a");
        // If clicked on download link or a link that should behave normally, let it
        if (link && link.hasAttribute("download")) {
          return;
        }

        const archivo = card.dataset.archivo;
        const title = card.dataset.title;
        const date = card.dataset.date;

        if (archivo && archivo.toLowerCase().endsWith(".pdf")) {
          openPdfModal(title, date, archivo);
        } else if (archivo) {
          window.open(archivo, "_blank");
        }
      });
    });

    activate("comunicados");
  })();
</script>

<style is:global>
  @keyframes rcFadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
